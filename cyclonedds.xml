<?xml version="1.0"?>
<!--
  CycloneDDS configuration for Jetson ↔ Mac wired simulator link.
  Place a matching file on the Mac with the Mac's interface address
  (e.g. 192.168.55.100) and export CYCLONEDDS_URI.
-->
<CycloneDDS xmlns="https://cdds.io/config">
  <Domain id="42">
    <General>
      <Interfaces>
        <!-- Jetson wired interface for the simulator link -->
        <NetworkInterface address="192.168.55.1"/>
      </Interfaces>
      <AllowMulticast>true</AllowMulticast>
    </General>
    <Discovery>
      <Peers>
        <!-- Mac wired IP -->
        <Peer address="192.168.55.100"/>
        <!-- Jetson wired IP -->
        <Peer address="192.168.55.1"/>
      </Peers>
    </Discovery>
  </Domain>
</CycloneDDS>
