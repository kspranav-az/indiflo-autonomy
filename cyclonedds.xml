<?xml version="1.0"?>
<!--
  CycloneDDS configuration for Jetson ↔ Mac wired simulator link.
  Multicast discovery is disabled because the point-to-point USB/Ethernet
  link between Mac and Jetson does not forward DDS SPDP multicast. Discovery
  uses explicit unicast peers only.
-->
<CycloneDDS xmlns="https://cdds.io/config">
  <Domain id="42">
    <General>
      <Interfaces>
        <NetworkInterface address="192.168.55.1"/>
      </Interfaces>
      <AllowMulticast>false</AllowMulticast>
      <ParticipantIndex>auto</ParticipantIndex>
    </General>
    <Discovery>
      <Peers>
        <Peer address="192.168.55.100"/>
      </Peers>
    </Discovery>
  </Domain>
</CycloneDDS>
